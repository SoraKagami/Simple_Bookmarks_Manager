{
  "manifest_version": 3,
  "name": "Firefox-style Bookmark Manager for Chrome",
  "version": "0.1.1",
  "description": "A local Chrome bookmark manager inspired by Firefox Places Library patterns.",
  "minimum_chrome_version": "114",
  "permissions": [
    "bookmarks",
    "tabs"
  ],
  "action": {
    "default_title": "Open bookmark manager"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "chrome_url_overrides": {
    "bookmarks": "manager.html"
  }
}
